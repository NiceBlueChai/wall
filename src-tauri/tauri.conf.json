{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Wall",
    "version": "1.0.0",
    "identifier": "com.wall.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Wall",
                "width": 1280,
                "height": 800,
                "minWidth": 960,
                "minHeight": 640,
                "center": true,
                "decorations": false,
                "resizable": true
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": []
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis"],
        "shortDescription": "完全离线的 Windows 动态壁纸工具"
    }
}
